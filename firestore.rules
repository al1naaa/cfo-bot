rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - only the owner can read/write their own doc
    match /users/{userId} {
      allow read, write: if true; // custom auth, not Firebase Auth

      // History subcollection - only accessible by querying with correct uid
      match /history/{entryId} {
        allow read, write, delete: if true;
      }
    }
  }
}
